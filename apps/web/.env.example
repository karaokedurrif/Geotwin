# Web App Environment Variables

# ==================================================
# API Configuration
# ==================================================
# API URL (used for client-side fetches; update for production)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# ==================================================
# Cesium Ion Configuration
# ==================================================
# Cesium Ion Access Token
# Get your token from: https://ion.cesium.com/tokens
# Required for: World Terrain, Bing Maps imagery, Ion assets
# Free tier includes 1 GB/month, 50,000 requests/month
NEXT_PUBLIC_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# ==================================================
# Development
# ==================================================
NODE_ENV=development
